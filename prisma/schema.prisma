// Prisma Schema for Unified Faith Service
// Databases: unified_faith_auth (auth tables), unified_faith_users (user tables)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// User Management
// ============================================

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String?   @map("password_hash") // Nullable for OTP-only users, required for password users
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  phone        String?
  isActive     Boolean   @default(true) @map("is_active")
  isVerified   Boolean   @default(false) @map("is_verified")
  lastLoginAt  DateTime? @map("last_login_at")
  deletedAt    DateTime? @map("deleted_at") // Soft delete
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  userRoles     UserRole[]
  subscriptions Subscription[]

  // Hindu module back-relations
  hinduScriptureBookmarks    HinduScriptureBookmark[]
  hinduFavoriteDeityNames    UserFavoriteDeityName[]
  hinduFavoriteStotras       UserFavoriteStotra[]
  hinduFavoriteTemples       UserFavoriteTemple[]
  hinduFavoriteStories       UserFavoriteHinduStory[]
  japaCounters               JapaCounter[]
  japaGoals                  JapaGoal[]
  japaHistory                JapaHistory[]
  pujaLogs                   PujaLog[]

  @@index([email])
  @@index([phone])
  @@index([isActive, deletedAt])
  @@map("users")
}

// ============================================
// RBAC Tables
// ============================================

model Role {
  id           String   @id @default(uuid())
  name         String   @unique
  slug         String   @unique
  description  String?
  isSystemRole Boolean  @default(false) @map("is_system_role")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([slug])
  @@index([name])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  rolePermissions RolePermission[]

  @@index([slug])
  @@index([resource])
  @@index([name])
  @@map("permissions")
}

model UserRole {
  id         String   @id @default(uuid())
  userId     String   @map("user_id") // References User.id
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by") // User ID who assigned this role
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ============================================
// Authentication Tables
// ============================================

model OtpCode {
  id         String   @id @default(uuid())
  identifier String // email or phone
  codeHash   String   @map("code_hash")
  expiresAt  DateTime @map("expires_at")
  attempts   Int      @default(0)
  isUsed     Boolean  @default(false) @map("is_used")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@index([expiresAt])
  @@index([identifier, expiresAt, isUsed])
  @@map("otp_codes")
}

model RefreshToken {
  id         String    @id @default(uuid())
  tokenId    String    @unique @map("token_id")
  userId     String    @map("user_id") // References User.id
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  isRevoked  Boolean   @default(false) @map("is_revoked")
  deviceInfo Json?     @map("device_info") // { name, ip, userAgent }
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([tokenId])
  @@index([userId, isRevoked, expiresAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================
// User Profile (Users Service)
// Database: unified_faith_users
// ============================================

model UserProfile {
  id          String    @id @default(uuid())
  userId      String    @unique @map("user_id") // References auth.users.id (cross-database)
  avatarUrl   String?   @map("avatar_url")
  bio         String?
  dateOfBirth DateTime? @map("date_of_birth")
  gender      String? // 'male', 'female', 'other', 'prefer_not_to_say'
  address     Json? // { street, city, state, zip, country }
  socialLinks Json?     @map("social_links") // { facebook, instagram, twitter }
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("user_profiles")
}

// ============================================
// User Preferences (Users Service)
// Database: unified_faith_users
// ============================================

model UserPreference {
  id                      String   @id @default(uuid())
  userId                  String   @unique @map("user_id") // References auth.users.id (cross-database)
  faith                   String? // 'hindu', 'muslim', 'christian', 'jain', 'sikh', 'buddhist'
  language                String? // 'en', 'hi', 'ta', 'te', 'kn', 'ml', 'mr', 'gu', 'bn', 'pa'
  countryCode             String?  @map("country_code") // ISO 3166-1 alpha-2
  timezone                String? // IANA timezone
  notificationPreferences Json?    @default("{}") @map("notification_preferences")
  contentPreferences      Json?    @default("{}") @map("content_preferences")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([faith])
  @@index([language])
  @@index([countryCode])
  @@map("user_preferences")
}

// ============================================
// Device Tokens (FCM/APNS) for Push Notifications
// Database: unified_faith_users
// ============================================

model DeviceToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id") // References auth.users.id (cross-database)
  token      String // FCM token or APNS device token
  platform   String // 'android', 'ios', 'web'
  deviceId   String?   @map("device_id") // Unique device identifier
  deviceName String?   @map("device_name") // User-friendly device name
  isActive   Boolean   @default(true) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([userId, token]) // One token per user (can update existing)
  @@index([userId])
  @@index([userId, isActive])
  @@index([token])
  @@map("device_tokens")
}

// ============================================
// Islamic Features - Prayer Times
// ============================================

model PrayerTime {
  id        String   @id @default(uuid())
  latitude  Float
  longitude Float
  date      DateTime @db.Date
  methodId  String   @map("method_id")
  fajr      DateTime
  sunrise   DateTime
  dhuhr     DateTime
  asr       DateTime
  maghrib   DateTime
  isha      DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([latitude, longitude, date, methodId])
  @@index([latitude, longitude, date])
  @@map("prayer_times")
}

model PrayerLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  prayerName String   @map("prayer_name") // fajr, dhuhr, asr, maghrib, isha
  date       DateTime @db.Date
  loggedAt   DateTime @map("logged_at")
  status     String // on_time, late, qada
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([userId, prayerName, date])
  @@index([userId, date])
  @@map("prayer_logs")
}

model CalculationMethod {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  fajrAngle   Float   @map("fajr_angle")
  ishaAngle   Float   @map("isha_angle")
  description String?

  @@map("calculation_methods")
}

model UserLocation {
  id                  String   @id @default(uuid())
  userId              String   @map("user_id")
  locationName        String   @map("location_name")
  latitude            Float
  longitude           Float
  timezone            String
  calculationMethodId String?  @map("calculation_method_id")
  isDefault           Boolean  @default(false) @map("is_default")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("user_locations")
}

// ============================================
// Islamic Features - Quran
// ============================================

model QuranSurah {
  id                  Int    @id
  nameArabic          String @map("name_arabic")
  nameEnglish         String @map("name_english")
  nameTransliteration String @map("name_transliteration")
  revelationPlace     String @map("revelation_place") // Meccan or Medinan
  verseCount          Int    @map("verse_count")

  verses QuranVerse[]

  @@map("quran_surahs")
}

model QuranVerse {
  id          String @id @default(uuid())
  surahId     Int    @map("surah_id")
  verseNumber Int    @map("verse_number")
  textArabic  String  @map("text_arabic") @db.Text
  textSimple  String  @map("text_simple") @db.Text
  textUthmani String? @map("text_uthmani") @db.Text

  surah           QuranSurah            @relation(fields: [surahId], references: [id])
  translations    QuranTranslation[]
  transliteration QuranTransliteration?

  @@unique([surahId, verseNumber])
  @@index([surahId])
  @@map("quran_verses")
}

model QuranTranslation {
  id         String  @id @default(uuid())
  verseId    String  @map("verse_id")
  language   String
  authorName String  @map("author_name")
  text       String  @db.Text
  isPremium  Boolean @default(false) @map("is_premium")

  verse QuranVerse @relation(fields: [verseId], references: [id])

  @@unique([verseId, authorName])
  @@index([verseId, language])
  @@index([authorName])
  @@map("quran_translations")
}

model QuranTransliteration {
  id      String @id @default(uuid())
  verseId String @unique @map("verse_id")
  text    String @db.Text

  verse QuranVerse @relation(fields: [verseId], references: [id])

  @@map("quran_transliterations")
}

model QuranReciter {
  id           String  @id @default(uuid())
  name         String  @unique
  slug         String  @unique
  nameArabic   String? @map("name_arabic")
  style        String?
  audioBaseUrl String  @map("audio_base_url")
  isPremium    Boolean @default(true) @map("is_premium")
  sortOrder    Int     @default(0) @map("sort_order")

  @@index([isPremium])
  @@map("quran_reciters")
}

model UserQuranBookmark {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  surahId     Int      @map("surah_id")
  verseNumber Int      @map("verse_number")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("user_quran_bookmarks")
}

model UserQuranProgress {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  lastSurahId     Int?     @map("last_surah_id")
  lastVerseNumber Int?     @map("last_verse_number")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("user_quran_progress")
}

// ============================================
// Islamic Features - Dhikr
// ============================================

model DhikrCounter {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  name           String
  phraseArabic   String   @map("phrase_arabic")
  phraseTranslit String?  @map("phrase_transliteration")
  phraseEnglish  String   @map("phrase_english")
  count          Int      @default(0)
  targetCount    Int?     @map("target_count")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([userId, isActive])
  @@index([phraseArabic])
  @@map("dhikr_counters")
}

model DhikrGoal {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  phraseArabic   String   @map("phrase_arabic")
  phraseTranslit String?  @map("phrase_transliteration")
  phraseEnglish  String   @map("phrase_english")
  targetCount    Int      @map("target_count")
  period         String // daily, weekly, monthly
  startDate      DateTime @map("start_date") @db.Date
  endDate        DateTime @map("end_date") @db.Date
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("dhikr_goals")
}

model DhikrHistory {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  phraseArabic   String   @map("phrase_arabic")
  phraseTranslit String?  @map("phrase_transliteration")
  phraseEnglish  String   @map("phrase_english")
  count          Int
  date           DateTime @db.Date
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([userId, phraseArabic, date])
  @@index([userId, date])
  @@map("dhikr_history")
}

// ============================================
// Islamic Features - Calendar
// ============================================

model HijriDate {
  id            String   @id @default(uuid())
  gregorianDate DateTime @unique @db.Date
  hijriDay      Int      @map("hijri_day")
  hijriMonth    Int      @map("hijri_month")
  hijriYear     Int      @map("hijri_year")

  @@index([hijriYear, hijriMonth, hijriDay])
  @@map("hijri_dates")
}

model IslamicEvent {
  id          String  @id @default(uuid())
  name        String
  nameArabic  String? @map("name_arabic")
  description String?
  hijriMonth  Int     @map("hijri_month")
  hijriDay    Int     @map("hijri_day")
  importance  String // major, moderate, minor

  @@unique([hijriMonth, hijriDay, name], name: "hijriMonth_hijriDay_name")
  @@index([hijriMonth, hijriDay])
  @@map("islamic_events")
}

// ============================================
// Islamic Features - Duas
// ============================================

model Dua {
  id            String @id @default(uuid())
  categoryId    String @map("category_id")
  titleArabic   String @map("title_arabic")
  titleEnglish  String @map("title_english")
  textArabic    String @map("text_arabic") @db.Text
  textTranslit  String? @map("text_transliteration") @db.Text
  textEnglish   String @map("text_english") @db.Text
  reference     String?
  audioUrl      String? @map("audio_url")

  category DuaCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@map("duas")
}

model DuaCategory {
  id          String  @id @default(uuid())
  name        String  @unique
  nameArabic  String? @map("name_arabic")
  description String?

  duas Dua[]

  @@map("dua_categories")
}

model UserCustomDua {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  text      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("user_custom_duas")
}

model UserFavoriteDua {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  duaId     String   @map("dua_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, duaId])
  @@index([userId])
  @@map("user_favorite_duas")
}

// ============================================
// Islamic Features - Hadith Collections
// ============================================

model HadithBook {
  id           String  @id @default(uuid())
  name         String  @unique
  nameArabic   String  @map("name_arabic")
  author       String
  authorArabic String  @map("author_arabic")
  totalHadiths Int     @map("total_hadiths")
  isPremium    Boolean @default(true) @map("is_premium")
  description  String? @db.Text
  sortOrder    Int     @default(0) @map("sort_order")

  hadiths Hadith[]

  @@index([isPremium])
  @@map("hadith_books")
}

model Hadith {
  id                  String  @id @default(uuid())
  bookId              String  @map("book_id")
  hadithNumber        Int     @map("hadith_number")
  chapterTitle        String? @map("chapter_title")
  chapterTitleArabic  String? @map("chapter_title_arabic")
  textArabic          String  @map("text_arabic") @db.Text
  textEnglish         String  @map("text_english") @db.Text
  narratorChain       String? @map("narrator_chain") @db.Text
  narratorChainArabic String? @map("narrator_chain_arabic") @db.Text
  grade               String?
  reference           String?

  book HadithBook @relation(fields: [bookId], references: [id])

  @@unique([bookId, hadithNumber])
  @@index([bookId])
  @@index([grade])
  @@map("hadiths")
}

model UserFavoriteHadith {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  hadithId  String   @map("hadith_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, hadithId])
  @@index([userId])
  @@map("user_favorite_hadiths")
}

// ============================================
// Islamic Features - Names of Allah
// ============================================

model AllahName {
  id           Int     @id
  nameArabic   String  @map("name_arabic")
  nameTranslit String  @map("name_transliteration")
  nameEnglish  String  @map("name_english")
  meaning      String
  description  String? @db.Text
  audioUrl     String? @map("audio_url")

  @@map("allah_names")
}

model UserFavoriteAllahName {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  nameId    Int      @map("name_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, nameId])
  @@index([userId])
  @@map("user_favorite_allah_names")
}

// ============================================
// Islamic Features - Names of Muhammad
// ============================================

model MuhammadName {
  id           Int     @id
  nameArabic   String  @map("name_arabic")
  nameTranslit String  @map("name_transliteration")
  nameEnglish  String  @map("name_english")
  meaning      String
  description  String? @db.Text
  audioUrl     String? @map("audio_url")

  @@map("muhammad_names")
}

model UserFavoriteMuhammadName {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  nameId    Int      @map("name_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, nameId])
  @@index([userId])
  @@map("user_favorite_muhammad_names")
}

// ============================================
// Islamic Features - Qibla
// ============================================

model QiblaCache {
  id        String   @id @default(uuid())
  latitude  Float
  longitude Float
  direction Float // Degrees from north
  distance  Float // Distance to Kaaba in km
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([latitude, longitude])
  @@map("qibla_cache")
}


// ============================================
// Islamic Features - Feelings / Emotions
// ============================================

model Emotion {
  id        String          @id @default(uuid())
  name      String          @unique
  slug      String          @unique
  icon      String?         // Emoji or icon name
  remedies  EmotionRemedy[]
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@map("emotions")
}

model EmotionRemedy {
  id              String   @id @default(uuid())
  arabicText      String   @map("arabic_text") @db.Text
  transliteration String?  @db.Text
  translation     String   @db.Text
  source          String   // e.g., "Quran 2:153", "Sahih Bukhari 1234"
  emotionId       String   @map("emotion_id")
  emotion         Emotion  @relation(fields: [emotionId], references: [id])
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([emotionId])
  @@map("emotion_remedies")
}

// ============================================
// Subscriptions / Payments
// ============================================

model Subscription {
  id                     String    @id @default(uuid())
  userId                 String    @map("user_id")
  razorpaySubscriptionId String    @unique @map("razorpay_subscription_id")
  razorpayPlanId         String    @map("razorpay_plan_id")
  plan                   String    // 'monthly' | 'yearly'
  status                 String    @default("created") // created | authenticated | active | pending | halted | cancelled | completed
  currentPeriodStart     DateTime? @map("current_period_start")
  currentPeriodEnd       DateTime? @map("current_period_end")
  cancelledAt            DateTime? @map("cancelled_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

// ============================================================================
// HINDU MODULE
// ============================================================================
// All Hindu tables prefixed `hindu_` to keep them grep-able alongside Islam.
// Single migration `add_hindu_module` introduces this entire block.
// ============================================================================

// ----- Deities & Names -----

model Deity {
  id            String        @id @default(uuid())
  slug          String        @unique
  nameEnglish   String        @map("name_english")
  nameSanskrit  String        @map("name_sanskrit")
  family        String?       // 'vaishnava' | 'shaiva' | 'shakta' | 'smarta' | 'pan'
  color         String?       // hex color for UI badge
  traditions    String[]
  createdAt     DateTime      @default(now()) @map("created_at")
  names         DeityName[]

  @@map("hindu_deities")
}

model DeityName {
  id              String                  @id @default(uuid())
  deityId         String                  @map("deity_id")
  sequence        Int
  sanskritName    String                  @map("sanskrit_name")
  transliteration String
  hindiName       String?                 @map("hindi_name")
  englishMeaning  String                  @map("english_meaning")
  description     String?
  createdAt       DateTime                @default(now()) @map("created_at")
  deity           Deity                   @relation(fields: [deityId], references: [id], onDelete: Cascade)
  favorites       UserFavoriteDeityName[]

  @@index([deityId, sequence])
  @@map("hindu_deity_names")
}

model UserFavoriteDeityName {
  id           String     @id @default(uuid())
  userId       String     @map("user_id")
  deityNameId  String     @map("deity_name_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deityName    DeityName  @relation(fields: [deityNameId], references: [id], onDelete: Cascade)

  @@unique([userId, deityNameId])
  @@map("hindu_user_favorite_deity_names")
}

// ----- Scriptures (Bhagavad Gita, Sahasranama, Chalisa, Upanishads) -----

model HinduText {
  id              String                   @id @default(uuid())
  slug            String                   @unique
  nameEnglish     String                   @map("name_english")
  nameSanskrit    String                   @map("name_sanskrit")
  type            String                   // 'gita' | 'sahasranama' | 'chalisa' | 'upanishad' | 'purana'
  totalVerses     Int                      @map("total_verses")
  isPremium       Boolean                  @default(false) @map("is_premium")
  createdAt       DateTime                 @default(now()) @map("created_at")
  chapters        HinduTextChapter[]
  verses          HinduTextVerse[]
  audios          HinduTextAudio[]

  @@map("hindu_texts")
}

model HinduTextChapter {
  id            String           @id @default(uuid())
  textId        String           @map("text_id")
  chapterNumber Int              @map("chapter_number")
  nameSanskrit  String?          @map("name_sanskrit")
  nameEnglish   String?          @map("name_english")
  text          HinduText        @relation(fields: [textId], references: [id], onDelete: Cascade)
  verses        HinduTextVerse[]
  audios        HinduTextAudio[]

  @@unique([textId, chapterNumber])
  @@map("hindu_text_chapters")
}

model HinduTextVerse {
  id              String                   @id @default(uuid())
  textId          String                   @map("text_id")
  chapterId       String?                  @map("chapter_id")
  verseNumber     Int                      @map("verse_number")
  sanskritText    String                   @map("sanskrit_text")
  transliteration String?
  createdAt       DateTime                 @default(now()) @map("created_at")
  text            HinduText                @relation(fields: [textId], references: [id], onDelete: Cascade)
  chapter         HinduTextChapter?        @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  translations    HinduTextTranslation[]
  bookmarks       HinduScriptureBookmark[]
  emotionRemedies HinduEmotionRemedy[]

  @@index([textId, chapterId, verseNumber])
  @@map("hindu_text_verses")
}

model HinduTextTranslation {
  id            String          @id @default(uuid())
  verseId       String          @map("verse_id")
  languageCode  String          @map("language_code")  // 'en' | 'hi' | 'sa' | 'ta' | 'bn'
  authorName    String          @map("author_name")
  text          String
  isPremium     Boolean         @default(false) @map("is_premium")
  createdAt     DateTime        @default(now()) @map("created_at")
  verse         HinduTextVerse  @relation(fields: [verseId], references: [id], onDelete: Cascade)

  @@unique([verseId, languageCode, authorName])
  @@map("hindu_text_translations")
}

model HinduTextAudio {
  id            String             @id @default(uuid())
  textId        String             @map("text_id")
  chapterId     String?            @map("chapter_id")
  reciterSlug   String             @map("reciter_slug")
  url           String
  isPremium     Boolean            @default(false) @map("is_premium")
  createdAt     DateTime           @default(now()) @map("created_at")
  text          HinduText          @relation(fields: [textId], references: [id], onDelete: Cascade)
  chapter       HinduTextChapter?  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@map("hindu_text_audio")
}

model HinduScriptureBookmark {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  verseId     String          @map("verse_id")
  note        String?
  createdAt   DateTime        @default(now()) @map("created_at")
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  verse       HinduTextVerse  @relation(fields: [verseId], references: [id], onDelete: Cascade)

  @@unique([userId, verseId])
  @@map("hindu_scripture_bookmarks")
}

// ----- Japa (mantra counter) -----

model JapaCounter {
  id             String     @id @default(uuid())
  userId         String     @map("user_id")
  name           String
  mantraSanskrit String?    @map("mantra_sanskrit")
  mantraEnglish  String?    @map("mantra_english")
  count          Int        @default(0)
  targetCount    Int?       @map("target_count")
  deityKey       String?    @map("deity_key")
  isActive       Boolean    @default(true) @map("is_active")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("hindu_japa_counters")
}

model JapaGoal {
  id             String     @id @default(uuid())
  userId         String     @map("user_id")
  mantraSanskrit String     @map("mantra_sanskrit")
  targetCount    Int        @map("target_count")
  period         String     // 'daily' | 'weekly' | 'monthly'
  startDate      DateTime   @map("start_date")
  endDate        DateTime   @map("end_date")
  createdAt      DateTime   @default(now()) @map("created_at")
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("hindu_japa_goals")
}

model JapaHistory {
  id        String     @id @default(uuid())
  userId    String     @map("user_id")
  mantra    String
  count     Int
  date      DateTime
  createdAt DateTime   @default(now()) @map("created_at")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("hindu_japa_history")
}

// ----- Panchang (festivals + puja log) -----

model HinduFestival {
  id            String   @id @default(uuid())
  slug          String   @unique
  nameEnglish   String   @map("name_english")
  nameSanskrit  String?  @map("name_sanskrit")
  nameHindi     String?  @map("name_hindi")
  ruleSpec      Json     @map("rule_spec")
  deityKey      String?  @map("deity_key")
  regions       String[]
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("hindu_festivals")
}

model PujaLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  sandhya   String   // 'pratah' | 'madhyahna' | 'sayam'
  date      DateTime
  status    String   // 'on_time' | 'late' | 'missed'
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("hindu_puja_logs")
}

// ----- Stotras / Aartis / Bhajans -----

model StotraCategory {
  id        String    @id @default(uuid())
  slug      String    @unique
  name      String
  deityKey  String?   @map("deity_key")
  createdAt DateTime  @default(now()) @map("created_at")
  stotras   Stotra[]

  @@map("hindu_stotra_categories")
}

model Stotra {
  id              String                @id @default(uuid())
  categoryId      String                @map("category_id")
  slug            String                @unique
  titleSanskrit   String                @map("title_sanskrit")
  titleEnglish    String                @map("title_english")
  type            String                // 'stotra' | 'aarti' | 'bhajan'
  deityKey        String?               @map("deity_key")
  isPremium       Boolean               @default(false) @map("is_premium")
  createdAt       DateTime              @default(now()) @map("created_at")
  category        StotraCategory        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  verses          StotraVerse[]
  audios          StotraAudio[]
  favorites       UserFavoriteStotra[]

  @@map("hindu_stotras")
}

model StotraVerse {
  id              String              @id @default(uuid())
  stotraId        String              @map("stotra_id")
  verseNumber     Int                 @map("verse_number")
  sanskritText    String              @map("sanskrit_text")
  transliteration String?
  stotra          Stotra              @relation(fields: [stotraId], references: [id], onDelete: Cascade)
  translations    StotraTranslation[]

  @@unique([stotraId, verseNumber])
  @@map("hindu_stotra_verses")
}

model StotraTranslation {
  id            String       @id @default(uuid())
  verseId       String       @map("verse_id")
  languageCode  String       @map("language_code")
  text          String
  verse         StotraVerse  @relation(fields: [verseId], references: [id], onDelete: Cascade)

  @@unique([verseId, languageCode])
  @@map("hindu_stotra_translations")
}

model StotraAudio {
  id          String   @id @default(uuid())
  stotraId    String   @map("stotra_id")
  reciterSlug String   @map("reciter_slug")
  url         String
  stotra      Stotra   @relation(fields: [stotraId], references: [id], onDelete: Cascade)

  @@map("hindu_stotra_audio")
}

model UserFavoriteStotra {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  stotraId  String   @map("stotra_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stotra    Stotra   @relation(fields: [stotraId], references: [id], onDelete: Cascade)

  @@unique([userId, stotraId])
  @@map("hindu_user_favorite_stotras")
}

// ----- Temple locator -----

model Temple {
  id            String                @id @default(uuid())
  name          String
  deityKey      String?               @map("deity_key")
  lat           Float
  lng           Float
  address       String
  city          String?
  country       String
  photos        String[]
  googlePlaceId String?               @map("google_place_id")
  source        String                // 'curated' | 'google'
  createdAt     DateTime              @default(now()) @map("created_at")
  favorites     UserFavoriteTemple[]

  @@index([lat, lng])
  @@map("hindu_temples")
}

model UserFavoriteTemple {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  templeId  String   @map("temple_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  temple    Temple   @relation(fields: [templeId], references: [id], onDelete: Cascade)

  @@unique([userId, templeId])
  @@map("hindu_user_favorite_temples")
}

// ----- Feelings (mood → Gita verse) -----

model HinduEmotion {
  id          String                 @id @default(uuid())
  slug        String                 @unique
  nameEnglish String                 @map("name_english")
  nameHindi   String?                @map("name_hindi")
  icon        String?
  createdAt   DateTime               @default(now()) @map("created_at")
  remedies    HinduEmotionRemedy[]

  @@map("hindu_emotions")
}

model HinduEmotionRemedy {
  id        String          @id @default(uuid())
  emotionId String          @map("emotion_id")
  verseId   String          @map("verse_id")
  note      String?
  sequence  Int             @default(0)
  emotion   HinduEmotion    @relation(fields: [emotionId], references: [id], onDelete: Cascade)
  verse     HinduTextVerse  @relation(fields: [verseId], references: [id], onDelete: Cascade)

  @@unique([emotionId, verseId])
  @@index([emotionId, sequence])
  @@map("hindu_emotion_remedies")
}

// ----- Sacred Stories -----

model HinduStoryCollection {
  id          String          @id @default(uuid())
  slug        String          @unique
  name        String
  sourceText  String          @map("source_text") // 'bhagavata_purana' | 'ramayana' | 'saint_lives' | 'panchatantra'
  isPremium   Boolean         @default(false) @map("is_premium")
  createdAt   DateTime        @default(now()) @map("created_at")
  stories     HinduStory[]

  @@map("hindu_story_collections")
}

model HinduStory {
  id            String                    @id @default(uuid())
  collectionId  String                    @map("collection_id")
  storyNumber   Int?                      @map("story_number")
  title         String
  summary       String
  body          String
  deityKey      String?                   @map("deity_key")
  characters    String[]
  createdAt     DateTime                  @default(now()) @map("created_at")
  collection    HinduStoryCollection      @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  translations  HinduStoryTranslation[]
  favorites     UserFavoriteHinduStory[]

  @@map("hindu_stories")
}

model HinduStoryTranslation {
  id            String      @id @default(uuid())
  storyId       String      @map("story_id")
  languageCode  String      @map("language_code")
  body          String
  story         HinduStory  @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, languageCode])
  @@map("hindu_story_translations")
}

model UserFavoriteHinduStory {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  storyId   String      @map("story_id")
  createdAt DateTime    @default(now()) @map("created_at")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  story     HinduStory  @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@map("hindu_user_favorite_stories")
}
